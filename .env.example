# ─────────────────────────────────────────────────────────────────────────────
# APK Builder Pro — Local Configuration
# Copy this file to .env and fill in your values before running run-local.bat
# ─────────────────────────────────────────────────────────────────────────────

# ── PostgreSQL Database (REQUIRED) ───────────────────────────────────────────
# Free cloud options:
#   Neon     → https://neon.tech       (recommended, serverless)
#   Supabase → https://supabase.com    (also great)
# Local PostgreSQL:
#   postgresql://postgres:yourpassword@localhost:5432/apkbuilder
DATABASE_URL=postgresql://user:password@host:5432/dbname

# ── Session Secret (REQUIRED) ─────────────────────────────────────────────────
# Used to sign session cookies. Must be a long random string.
# TIP: run-local.bat auto-generates one each run if this is missing,
#      but setting it here ensures sessions persist across restarts.
# Generate one: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=change-this-to-a-long-random-string-at-least-32-chars

# ── Gemini AI API Keys (OPTIONAL) ────────────────────────────────────────────
# Needed for the AI Assistant chat feature.
# Get free keys from: https://aistudio.google.com/app/apikey
# You can add up to 5 keys in Settings → Gemini API Keys (auto-rotates on quota).
#
# If you have a Replit AI Integration proxy, use these instead:
# AI_INTEGRATIONS_GEMINI_API_KEY=your_replit_proxy_key
# AI_INTEGRATIONS_GEMINI_BASE_URL=https://your-proxy-url
