# Copy this file to .env and fill in your values

# PostgreSQL Database (required)
# Free options: https://neon.tech | https://supabase.com | local PostgreSQL
DATABASE_URL=postgresql://user:password@localhost:5432/apkbuilder

# Session secret (required for API server)
SESSION_SECRET=change-this-to-a-long-random-string

# Gemini AI Integration (optional — needed for AI chat assistant)
# Get these from Replit AI Integrations panel
AI_INTEGRATIONS_GEMINI_API_KEY=
AI_INTEGRATIONS_GEMINI_BASE_URL=
